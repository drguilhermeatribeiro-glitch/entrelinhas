# Copie para .env e preencha. Em produção (Vercel), defina estas variáveis
# no painel do projeto (Settings → Environment Variables).

# Banco de dados
# Local (desenvolvimento): SQLite em arquivo
#   DATABASE_URL="file:./dev.db"
# Produção: string de conexão PostgreSQL da Neon (começa com postgresql://)
DATABASE_URL="postgresql://USUARIO:SENHA@HOST.neon.tech/NOME_DB?sslmode=require"

# Login da área administrativa (/admin)
ADMIN_EMAIL="admin@entrelinhas.com"
ADMIN_PASSWORD="troque-esta-senha"

# Segredo para assinar a sessão (gere um valor aleatório longo)
AUTH_SECRET="gere-um-segredo-aleatorio-bem-longo"

# Envio da newsletter (opcional)
# RESEND_API_KEY=""
# NEWSLETTER_FROM="Entrelinhas <contato@seudominio.com>"
